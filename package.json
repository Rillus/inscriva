{
  "name": "inscriva",
  "private": true,
  "version": "0.0.1",
  "description": "Web-first, local-first Markdown writing environment for long-form fiction",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @inscriva/web dev",
    "dev:bridge": "pnpm --filter @inscriva/dev-bridge dev",
    "dev:bridge:stop": "pnpm --filter @inscriva/dev-bridge stop",
    "dev:all": "pnpm --parallel --filter @inscriva/web --filter @inscriva/dev-bridge dev",
    "dev:desktop": "pnpm --filter @inscriva/desktop-macos dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @inscriva/web build",
    "build:desktop": "pnpm --filter @inscriva/desktop-macos build",
    "icon:render": "node scripts/render-app-icon.mjs",
    "test": "pnpm -r test && vitest run scripts/render-app-icon.test.mjs",
    "test:coverage": "pnpm -r test:coverage",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.9.0",
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@vitest/coverage-v8": "^3.2.4",
    "pngjs": "^7.0.0",
    "vitest": "^3.2.4"
  }
}
